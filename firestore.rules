rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers --------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ---- users ----------------------------------------------------------
    // Document id must equal the user's own uid.
    match /users/{userId} {
      // Signed-in users can read profiles, so listing cards can show a seller.
      allow read: if isSignedIn();

      allow create: if isSelf(userId)
                    && incoming().uid == userId
                    && incoming().email is string;

      // A user cannot change their uid or email here, and cannot promote
      // themselves to a verified student.
      allow update: if isSelf(userId)
                    && incoming().uid == existing().uid
                    && incoming().email == existing().email
                    && incoming().isVerifiedStudent == existing().isVerifiedStudent;

      allow delete: if false;
    }

    // ---- listings -------------------------------------------------------
    // Anyone signed in can browse. Only the seller can change their own rows.
    match /listings/{listingId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && incoming().sellerId == request.auth.uid
                    && incoming().title is string
                    && incoming().title.size() > 0
                    && incoming().title.size() <= 80
                    && incoming().price is int
                    && incoming().price >= 0
                    && incoming().status in ['active', 'sold']
                    // Forces a server timestamp rather than the device clock.
                    && incoming().createdAt == request.time;

      allow update: if isSignedIn()
                    && existing().sellerId == request.auth.uid
                    // Ownership and creation time are immutable.
                    && incoming().sellerId == existing().sellerId
                    && incoming().createdAt == existing().createdAt
                    && incoming().title.size() > 0
                    && incoming().title.size() <= 80
                    && incoming().price >= 0
                    && incoming().status in ['active', 'sold'];

      allow delete: if isSignedIn()
                    && existing().sellerId == request.auth.uid;
    }

    // Anything not matched above is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
